{
  "name": "tickerdb",
  "version": "0.1.6",
  "description": "Official Node.js/TypeScript SDK for the TickerDB financial data API",
  "author": "TickerDB",
  "license": "MIT",
  "homepage": "https://tickerdb.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/tickerdb/tickerdb-js"
  },
  "keywords": [
    "tickerdb",
    "finance",
    "stocks",
    "crypto",
    "etf",
    "market-data",
    "api",
    "sdk",
    "typescript"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:esm": "npx tsc --project tsconfig.esm.json",
    "build:cjs": "npx tsc --project tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
